{
  "name": "@pokeatlas/database",
  "version": "0.1.0",
  "main": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:migrate:resolve": "bunx --bun prisma migrate resolve",
    "db:deploy": "bunx --bun prisma migrate deploy",
    "db:studio": "bunx --bun prisma studio",
    "db:seed": "bunx --bun prisma db seed"
  },
  "dependencies": {
    "@context/collection": "workspace:*",
    "@context/progress": "workspace:*",
    "@context/shared": "workspace:*",
    "@pokeatlas/toolkit": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}