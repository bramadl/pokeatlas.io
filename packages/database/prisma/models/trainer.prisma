model TrainerModel {
  id String @id @default(uuid()) @db.Uuid

  name String

  trackedPokemons TrackedPokemonModel[]

  @@map("trainers")
  @@schema("trainer")
}

model TrackedPokemonModel {
  id String @id @default(uuid()) @db.Uuid

  pokemonForm String @map("pokemon_form")
  trainerId   String @map("trainer_id") @db.Uuid

  isShinyTracked           Boolean @map("is_shiny_tracked")
  isShadowTracked          Boolean @map("is_shadow_tracked")
  isPurifiedTracked        Boolean @map("is_purified_tracked")
  isLuckyTracked           Boolean @map("is_lucky_tracked")
  isHundoTracked           Boolean @map("is_hundo_tracked")
  isShinyShadowTracked     Boolean @map("is_shiny_shadow_tracked")
  isShinyPurifiedTracked   Boolean @map("is_shiny_purified_tracked")
  isShinyLuckyTracked      Boolean @map("is_shiny_lucky_tracked")
  isShinyHundoTracked      Boolean @map("is_shiny_hundo_tracked")
  isShinyLuckyHundoTracked Boolean @map("is_shiny_lucky_hundo_tracked")

  pokemon PokemonFormModel @relation(fields: [pokemonForm], references: [form], onDelete: Cascade)
  trainer TrainerModel     @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@map("tracked_pokemons")
  @@schema("trainer")
}
