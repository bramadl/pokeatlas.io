enum PokemonClass {
  LEGENDARY
  MYTHIC

  @@map("pokemon_class")
  @@schema("game")
}

model PokemonType {
  templateId String @id @map("template_id")

  name String

  syncedAt DateTime @updatedAt @map("synced_at")

  pokemonHavingAsPrimaryType   PokemonForm[] @relation(name: "PrimaryType")
  pokemonHavingAsSecondaryType PokemonForm[] @relation(name: "SecondaryType")

  @@map("pokemon_types")
  @@schema("game")
}

model PokemonSpecies {
  pokemonId String @id @map("pokemon_id")

  name String

  pokedexNumber Int           @map("pokedex_number")
  pokemonClass  PokemonClass? @map("pokemon_class")

  familyId          String  @map("family_id")
  isShadowAvailable Boolean @map("is_shadow_available")

  syncedAt DateTime @updatedAt @map("synced_at")

  forms PokemonForm[]

  @@map("pokemon_species")
  @@schema("game")
}

model PokemonForm {
  form String @id

  templateId String @map("template_id")
  speciesId  String @map("species_id")

  name String

  regularSprite String? @map("default_sprite")
  shinySprite   String? @map("shiny_sprite")

  primaryTypeId   String? @map("primary_type_id")
  secondaryTypeId String? @map("secondary_type_id")

  baseAttack  Int @map("base_attack")
  baseDefense Int @map("base_defense")
  baseStamina Int @map("base_stamina")

  height Float
  weight Float

  isCostume            Boolean @default(false) @map("is_costume")
  isTemporaryEvolution Boolean @default(false) @map("is_temporary_evolution")

  syncedAt DateTime @updatedAt @map("synced_at")

  species         PokemonSpecies   @relation(fields: [speciesId], references: [pokemonId], onDelete: Cascade)
  primaryType     PokemonType?     @relation(name: "PrimaryType", fields: [primaryTypeId], references: [templateId], onDelete: SetNull)
  secondaryType   PokemonType?     @relation(name: "SecondaryType", fields: [secondaryTypeId], references: [templateId], onDelete: SetNull)
  trackedPokemons TrackedPokemon[]

  @@map("pokemon_forms")
  @@schema("game")
}
