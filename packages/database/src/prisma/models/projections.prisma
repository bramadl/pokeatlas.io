model PokedexProjection {
  pokemonRef String @map("pokemon_ref")
  trainerRef String @map("trainer_ref") @db.Uuid

  imageUrl      String  @map("image_url")
  shinyImageUrl String? @map("shiny_image_url")

  form         String
  formCategory String @map("form_category")
  formPriority Int    @default(0) @map("form_priority")

  classification String?

  familyId    String @map("family_id")
  pokemonName String @map("pokemon_name")
  dexNumber   Int    @map("dex_number")
  sortGroup   Int?   @default(0) @map("sort_group")

  primaryType   String  @map("primary_type")
  secondaryType String? @map("secondary_type")

  isCostume            Boolean @default(false) @map("is_costume")
  isFemale             Boolean @default(false) @map("is_female")
  isTemporaryEvolution Boolean @default(false) @map("is_temporary_evolution")

  trackedStates String[] @default([]) @map("tracked_states")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([trainerRef, pokemonRef])
  @@index([trainerRef, dexNumber, formPriority])
  @@index([trainerRef, formCategory])
  @@index([trainerRef, isFemale])
  @@index([trainerRef, familyId])
  @@index([trainerRef, pokemonName])
  @@index([trainerRef, sortGroup, dexNumber, formPriority])
  @@map("pokedex")
  @@schema("projections")
}
