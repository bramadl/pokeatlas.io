model ProgressProjection {
  trainerId String @id @map("trainer_id") @db.Uuid

  speciesTracked       Int   @default(0) @map("species_tracked")
  speciesTotal         Int   @default(0) @map("species_total")
  completionPercentage Float @default(0) @map("completion_percentage")

  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trainer           TrainerModel                 @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  trackingProgress  TrackingProgressProjection[]
  regionalProgress  RegionalProgressProjection[]
  variantProgress   VariantProgressProjection[]
  latestAcquisition LatestAcquisitionProjection?

  @@map("trainer_progress")
  @@schema("projection")
}

model TrackingProgressProjection {
  trainerId     String @map("trainer_id") @db.Uuid
  trackingState String @map("tracking_state")

  speciesTracked       Int   @default(0) @map("species_tracked")
  speciesTotal         Int   @default(0) @map("species_total")
  completionPercentage Float @default(0) @map("completion_percentage")

  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trainer  TrainerModel       @relation(fields: [trainerId], references: [id], onDelete: Cascade, map: "fk_tracking_progress_trainer")
  progress ProgressProjection @relation(fields: [trainerId], references: [trainerId], onDelete: Cascade, map: "fk_tracking_progress_parent")

  @@id([trainerId, trackingState])
  @@map("trainer_tracking_progress")
  @@schema("projection")
}

model RegionalProgressProjection {
  trainerId String @map("trainer_id") @db.Uuid
  region    String

  speciesTracked       Int   @default(0) @map("species_tracked")
  speciesTotal         Int   @default(0) @map("species_total")
  completionPercentage Float @default(0) @map("completion_percentage")

  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trainer  TrainerModel       @relation(fields: [trainerId], references: [id], onDelete: Cascade, map: "fk_regional_progress_trainer")
  progress ProgressProjection @relation(fields: [trainerId], references: [trainerId], onDelete: Cascade, map: "fk_regional_progress_parent")

  @@id([trainerId, region])
  @@map("trainer_regional_progress")
  @@schema("projection")
}

model VariantProgressProjection {
  trainerId  String @map("trainer_id") @db.Uuid
  variantKey String @map("variant_key")

  speciesTracked       Int   @default(0) @map("species_tracked")
  speciesTotal         Int   @default(0) @map("species_total")
  completionPercentage Float @default(0) @map("completion_percentage")

  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trainer  TrainerModel       @relation(fields: [trainerId], references: [id], onDelete: Cascade, map: "fk_variant_progress_trainer")
  progress ProgressProjection @relation(fields: [trainerId], references: [trainerId], onDelete: Cascade, map: "fk_variant_progress_parent")

  @@id([trainerId, variantKey])
  @@map("trainer_variant_progress")
  @@schema("projection")
}

model LatestAcquisitionProjection {
  trainerId String @id @map("trainer_id") @db.Uuid

  pokemonRef    String   @map("pokemon_ref")
  dexNumber     Int      @map("dex_number")
  pokemonName   String   @map("pokemon_name")
  region        String
  primaryType   String   @map("primary_type")
  secondaryType String?  @map("secondary_type")
  sprite        String
  trackedStates String[] @map("tracked_states")
  activityType  String   @map("activity_type")

  occurredAt DateTime @map("occurred_at")

  trainer  TrainerModel       @relation(fields: [trainerId], references: [id], onDelete: Cascade, map: "fk_latest_acquisition_trainer")
  progress ProgressProjection @relation(fields: [trainerId], references: [trainerId], onDelete: Cascade, map: "fk_variant_progress_parent")

  @@map("trainer_latest_acquisition")
  @@schema("projection")
}

model CatchOfTheDayProjection {
  trainerId String @id @map("trainer_id") @db.Uuid
  date      String

  slots       Json
  generatedAt DateTime @map("generated_at")

  trainer TrainerModel @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@map("trainer_catch_of_the_day")
  @@schema("projection")
}

model TrainerAchievementProjection {
  trainerId  String   @map("trainer_id") @db.Uuid
  type       String
  achievedAt DateTime @map("achieved_at")
  metadata   Json?

  trainer TrainerModel @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@id([trainerId, type])
  @@map("trainer_achievements")
  @@schema("projection")
}
