model TrainerPokedexView {
  pokemonRef String @map("pokemon_ref")
  trainerRef String @map("trainer_ref") @db.Uuid

  pokemonName String @map("pokemon_name")
  dexNumber   Int    @map("dex_number")

  imageUrl      String? @map("image_url")
  shinyImageUrl String? @map("shiny_image_url")

  isTracked Boolean @map("is_tracked")

  formPriority Int @default(0) @map("form_priority")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([trainerRef, pokemonRef])
  @@index([trainerRef, dexNumber, formPriority])
  @@map("trainer_pokedex")
  @@schema("views")
}
