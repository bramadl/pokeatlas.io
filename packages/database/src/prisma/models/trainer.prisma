model TrainerModel {
  id String @id @default(uuid()) @db.Uuid

  name String

  trackedPokemons  TrackedPokemonModel[]
  progress         TrainerProgress?
  trackingProgress TrainerTrackingProgress[]
  regionalProgress TrainerRegionalProgress[]
  variantProgress  TrainerVariantProgress[]

  createdAt                 DateTime                  @default(now()) @map("created_at")
  updatedAt                 DateTime                  @updatedAt @map("updated_at")
  trainerLatestAcquisitions TrainerLatestAcquisition?

  @@map("trainers")
  @@schema("trainer")
}

model TrackedPokemonModel {
  id String @id @default(uuid()) @db.Uuid

  species   String @map("species")
  trainerId String @map("trainer_id") @db.Uuid

  trackedStates String[] @default([]) @map("tracked_states")

  pokemon PokemonModel @relation(fields: [species], references: [ref], onDelete: Cascade)
  trainer TrainerModel @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([species, trainerId])
  @@map("tracked_pokemons")
  @@schema("trainer")
}
