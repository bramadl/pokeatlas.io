model TrainerModel {
  id String @id @default(uuid()) @db.Uuid

  authId String? @unique @map("auth_id") @db.Uuid

  buddyPokemonId String? @map("buddy_pokemon_ref") @db.Uuid
  team           Team?

  auth              UserModel?                     @relation(fields: [authId], references: [id], onDelete: Cascade)
  trackedPokemons   TrackedPokemonModel[]
  progress          ProgressProjection?
  catchOfTheDay     CatchOfTheDayProjection?
  trackingProgress  TrackingProgressProjection[]
  regionalProgress  RegionalProgressProjection[]
  variantProgress   VariantProgressProjection[]
  latestAcquisition LatestAcquisitionProjection?
  achievements      TrainerAchievementProjection[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trainers")
  @@schema("trainer")
}

model TrackedPokemonModel {
  id String @id @default(uuid()) @db.Uuid

  species   String @map("species")
  trainerId String @map("trainer_id") @db.Uuid

  trackedStates String[] @default([]) @map("tracked_states")

  pokemon PokemonModel @relation(fields: [species], references: [ref], onDelete: Cascade)
  trainer TrainerModel @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([species, trainerId])
  @@map("tracked_pokemons")
  @@schema("trainer")
}
