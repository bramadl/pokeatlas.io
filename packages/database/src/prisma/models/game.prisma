enum PokemonClassification {
  LEGENDARY
  MYTHIC

  @@map("pokemon_classification")
  @@schema("game")
}

model PokemonTypeModel {
  templateId String @id @map("template_id")

  name String

  syncedAt DateTime @updatedAt @map("synced_at")

  pokemonHavingAsPrimaryType   PokemonFormModel[] @relation(name: "PrimaryType")
  pokemonHavingAsSecondaryType PokemonFormModel[] @relation(name: "SecondaryType")

  @@map("pokemon_types")
  @@schema("game")
}

model PokemonSpeciesModel {
  pokemonId String @id @map("pokemon_id")
  familyId  String @map("family_id")

  name String

  pokedexNumber         Int                    @map("pokedex_number")
  pokemonClassification PokemonClassification? @map("pokemon_classification")
  isShadowAvailable     Boolean                @map("is_shadow_available")

  syncedAt DateTime @updatedAt @map("synced_at")

  forms PokemonFormModel[]

  @@map("pokemon_species")
  @@schema("game")
}

model PokemonFormModel {
  form String @id

  templateId String @map("template_id")
  speciesId  String @map("species_id")

  name String

  regularSprite String  @map("default_sprite")
  shinySprite   String? @map("shiny_sprite")

  primaryTypeId   String  @map("primary_type_id")
  secondaryTypeId String? @map("secondary_type_id")

  baseAttack  Int @map("base_attack")
  baseDefense Int @map("base_defense")
  baseStamina Int @map("base_stamina")

  height Float
  weight Float

  isCostume            Boolean @default(false) @map("is_costume")
  isTemporaryEvolution Boolean @default(false) @map("is_temporary_evolution")

  syncedAt DateTime @updatedAt @map("synced_at")

  species         PokemonSpeciesModel   @relation(fields: [speciesId], references: [pokemonId], onDelete: Cascade)
  primaryType     PokemonTypeModel      @relation(name: "PrimaryType", fields: [primaryTypeId], references: [templateId], onDelete: Restrict)
  secondaryType   PokemonTypeModel?     @relation(name: "SecondaryType", fields: [secondaryTypeId], references: [templateId], onDelete: SetNull)
  trackedPokemons TrackedPokemonModel[]

  @@map("pokemon_forms")
  @@schema("game")
}
