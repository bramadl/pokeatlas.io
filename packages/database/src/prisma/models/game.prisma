enum PokemonClassification {
  LEGENDARY
  MYTHIC
  ULTRA_BEAST

  @@map("pokemon_classification")
  @@schema("game")
}

enum FormCategory {
  ALTERNATE_FORM
  BASE_FORM
  REGIONAL_FORM

  @@map("form_category")
  @@schema("game")
}

model PokemonTypeModel {
  templateId String @id @map("template_id")

  name String

  syncedAt DateTime @updatedAt @map("synced_at")

  pokemonHavingAsPrimaryType   PokemonModel[] @relation(name: "PrimaryType")
  pokemonHavingAsSecondaryType PokemonModel[] @relation(name: "SecondaryType")

  @@map("pokemon_types")
  @@schema("game")
}

model PokemonModel {
  ref String @id

  familyId   String @map("family_id")
  speciesId  String @map("species_id")
  templateId String @map("template_id")

  pokedexNumber         Int                    @map("pokedex_number")
  pokemonClassification PokemonClassification? @map("pokemon_classification")

  speciesName String @map("species_name")
  formName    String @map("form_name")
  region      String @map("region")

  regularSprite String  @map("default_sprite")
  shinySprite   String? @map("shiny_sprite")

  formCategory  FormCategory @default(BASE_FORM) @map("form_category")
  formPriority  Int          @map("form_priority")
  formSortGroup Int          @map("form_sort_group")
  isDefaultForm Boolean      @default(false) @map("is_default_form")

  isCostume            Boolean @default(false) @map("is_costume")
  isFemale             Boolean @default(false) @map("is_female")
  isShadowAvailable    Boolean @map("is_shadow_available")
  isTemporaryEvolution Boolean @default(false) @map("is_temporary_evolution")

  isTrackable Boolean @default(false) @map("is_trackable")
  isTradable  Boolean @default(true) @map("is_tradable")

  primaryTypeId   String  @map("primary_type_id")
  secondaryTypeId String? @map("secondary_type_id")

  baseAttack  Int @map("base_attack")
  baseDefense Int @map("base_defense")
  baseStamina Int @map("base_stamina")

  height Float
  weight Float

  syncedAt DateTime @updatedAt @map("synced_at")

  primaryType     PokemonTypeModel      @relation(name: "PrimaryType", fields: [primaryTypeId], references: [templateId], onDelete: Restrict)
  secondaryType   PokemonTypeModel?     @relation(name: "SecondaryType", fields: [secondaryTypeId], references: [templateId], onDelete: SetNull)
  trackedPokemons TrackedPokemonModel[]

  @@index(fields: [formSortGroup, pokedexNumber, formPriority, ref], map: "cursor_pagination")
  @@index(fields: [isTrackable, formSortGroup, pokedexNumber, formPriority, ref], map: "filter_is_trackable")
  @@index(fields: [pokedexNumber], map: "search_by_pokedex_number")
  @@index(fields: [formName], map: "search_by_form_name")
  @@index(fields: [speciesId], map: "regional_dex_filter")
  @@map("pokemon")
  @@schema("game")
}
