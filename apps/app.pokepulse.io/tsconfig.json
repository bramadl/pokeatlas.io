{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],

      "#collection:application/*": ["../../packages/contexts/collection-context/src/application/*"],
      "#collection:contracts/*": ["../../packages/contexts/collection-context/src/contracts/*"],
      "#collection:core/*": ["../../packages/contexts/collection-context/src/core/*"],
      
      "#prisma-client": ["../../packages/database/src/prisma/client.ts"],
      "#prisma-client/*": ["../../packages/database/src/prisma/generated/*"],
    },
  },
  "exclude": ["node_modules"],
  "extends": "../../packages/config/typescript/tsconfig.next.json",
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ]
}
