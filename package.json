{
  "name": "pokeatlas.io",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/contexts/*",
    "packages/core",
    "packages/database",
    "packages/pipelines",
    "packages/toolkit"
  ],
  "scripts": {
    "app:dev": "bun run --filter @pokeatlas/app.pokeatlas.io --smol dev",
    "app:build": "bun run --filter @pokeatlas/app.pokeatlas.io --smol build",
    "app:start": "bun run --filter @pokeatlas/app.pokeatlas.io --smol start",
    "biome:check": "biome check .",
    "biome:format": "biome format . --write",
    "biome:lint": "biome lint .",
    "db:deploy": "bun run --filter @pokeatlas/database db:deploy",
    "db:generate": "bun run --filter @pokeatlas/database db:generate",
    "db:migrate": "bun run --filter @pokeatlas/database db:migrate",
    "db:migrate:resolve": "bun run --filter @pokeatlas/database db:migrate:resolve",
    "db:seed": "bun run --filter @pokeatlas/database db:seed",
    "db:studio": "bun run --filter @pokeatlas/database db:studio",
    "etl:game": "cd packages/pipelines && bun run sync"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "typescript": "^5"
  }
}